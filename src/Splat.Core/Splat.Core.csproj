<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>$(SplatCoreTargets)</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Authors>.NET Foundation and Contributors</Authors>
    <Description>A library to make things cross-platform that should be, providing Builder and Dependency Injection abstractions and implementations. AOT compatible for .NET 8+</Description>
  </PropertyGroup>
  <PropertyGroup Condition="$(TargetFramework.StartsWith('net8.0')) or $(TargetFramework.StartsWith('net9.0')) or $(TargetFramework.StartsWith('net10.0'))">
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>
  <ItemGroup Condition="$(TargetFramework.StartsWith('net46'))">
    <PackageReference Include="System.ValueTuple" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ReactiveUI.Disposables" />
  </ItemGroup>

  <!-- IVT is granted to the test projects only, for white-box testing of internals. Production
       libraries no longer import Splat.Core internals over IVT — the shared polyfills/helpers are
       compiled into each assembly from src/Polyfills (see Directory.Build.props). -->
  <ItemGroup>
    <InternalsVisibleTo Include="Splat.Tests" />
    <InternalsVisibleTo Include="Splat.Drawing.Tests" />
    <InternalsVisibleTo Include="Splat.Logging.Tests" />
    <InternalsVisibleTo Include="Splat.Builder.Tests" />
    <InternalsVisibleTo Include="Splat.Common.Test" />
    <InternalsVisibleTo Include="Splat.Microsoft.Extensions.Logging.Tests" />
  </ItemGroup>
</Project>
